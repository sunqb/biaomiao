# Required: Baimiao account, mobile number or email.
BAIMIAO_USERNAME=your_account

# Required: Baimiao account password.
BAIMIAO_PASSWORD=your_password

# Optional: upstream HTTP request timeout in seconds.
BAIMIAO_REQUEST_TIMEOUT=15

# Optional: max OCR polling time in seconds.
BAIMIAO_OCR_TIMEOUT=60

# Optional: OCR polling interval in seconds.
BAIMIAO_POLL_INTERVAL=0.2
